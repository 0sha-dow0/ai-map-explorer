# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# AI provider selection
# Valid values: gemini | groq | ollama (defaults to gemini when unset)
AI_PROVIDER=gemini

# Gemini - required when AI_PROVIDER=gemini
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq - required when AI_PROVIDER=groq
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama - runs locally, no API key needed (https://ollama.com)
# OLLAMA_MODEL is required when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
